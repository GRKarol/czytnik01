{
  "name": "czytnik01",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Web flasher + PWA client app for the czytnik01 ESP32-S3 device",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,html,css}\" \"*.{html,ts,json,md}\""
  },
  "dependencies": {
    "esp-web-tools": "^10.1.0",
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/w3c-web-serial": "^1.0.7",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-pwa": "^0.20.5",
    "workbox-window": "^7.1.0"
  }
}
